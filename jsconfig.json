{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"]
        },
        "jsx": "preserve",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": false,
        "strict": false,
        "noEmit": true,
        "types": ["vite/client"]
    },
    "include": ["resources/js/**/*.js", "resources/js/**/*.vue", "resources/js/**/*.ts"]
}
