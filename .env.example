APP_NAME=Pennies
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_VERSION=0.1.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (local) ---
# SQLite (simplest local dev)
DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# PostgreSQL (matches Docker Compose stack)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=pennies
# DB_USERNAME=pennies
# DB_PASSWORD=pennies

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Redis + queues (use with Horizon / Docker worker)
# QUEUE_CONNECTION=redis
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- S3 / MinIO (self-hosted object storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=pennies
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Vite dev server (optional). With `npm run dev`, Vue/CSS hot-reloads by default.
# Use these when the browser cannot reach the HMR WebSocket (Docker bind-mount dev, LAN URL, VM):
# VITE_DEV_SERVER_HOST=0.0.0.0
# VITE_DEV_SERVER_PORT=5173
# VITE_DEV_SERVER_HMR_HOST=localhost
# VITE_DEV_SERVER_HMR_PORT=5173
# VITE_DEV_SERVER_USE_POLLING=true

# Stripe (Laravel Cashier)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# --- Docker Compose (`docker compose up -d`) — production-style stack ---
# The compose file sets sensible defaults for app, worker, scheduler, Postgres 16,
# Redis 7, and MinIO (API :9000, console :9001). Named volumes: mysql_data (Postgres
# data — name kept from project prompt), redis_data, minio_data, storage_data.
#
# Before first run: copy this file to `.env`, run `php artisan key:generate`, then
# either merge variables into compose or use the inline defaults in compose.yaml.
#
# MinIO dev credentials (change in production):
#   MINIO_ROOT_USER=minio
#   MINIO_ROOT_PASSWORD=miniosecretchange
#
# Object storage for the app container:
#   FILESYSTEM_DISK=s3
#   AWS_ENDPOINT=http://minio:9000
#   AWS_URL=http://localhost:9000
#   AWS_USE_PATH_STYLE_ENDPOINT=true
#   AWS_ACCESS_KEY_ID=minio
#   AWS_SECRET_ACCESS_KEY=miniosecretchange

# --- Laravel Sail (`compose.sail.yaml`) ---
# Local dev stack aligned with production: Postgres 16, Redis 7, MinIO, Mailpit.
# Do not run Sail and the production compose MinIO both on host port 9000.
#
#   composer sail -- up -d
#   composer sail -- artisan migrate
#   composer sail -- npm run dev
#
# Typical `.env` when using Sail:
#   DB_CONNECTION=pgsql
#   DB_HOST=pgsql
#   DB_DATABASE=pennies
#   DB_USERNAME=pennies
#   DB_PASSWORD=pennies
#   REDIS_HOST=redis
#   SESSION_DRIVER=redis
#   CACHE_STORE=redis
#   QUEUE_CONNECTION=redis
#   MAIL_MAILER=smtp
#   MAIL_HOST=mailpit
#   MAIL_PORT=1025
#   FILESYSTEM_DISK=s3 + AWS_* pointing at MinIO (same as production compose)
#
# Optional host port overrides: FORWARD_DB_PORT, FORWARD_REDIS_PORT, FORWARD_MINIO_PORT,
# FORWARD_MINIO_CONSOLE_PORT, FORWARD_MAILPIT_PORT, FORWARD_MAILPIT_DASHBOARD_PORT
#
# Docker user IDs (Linux): match `id -u` / `id -g` if permission errors on bind mounts:
#   WWWUSER=1000
#   WWWGROUP=1000
