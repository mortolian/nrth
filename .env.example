APP_NAME=nrth
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://localhost:8000
APP_VERSION=0.1.0

# HTTPS — required on any server (financial app). Set APP_ALLOW_HTTP=true only for local dev.
APP_FORCE_HTTPS=true
APP_ALLOW_HTTP=true
TRUSTED_PROXIES=*
# SESSION_SECURE_COOKIE defaults to true when APP_ALLOW_HTTP=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (local) ---
# SQLite (simplest local dev)
DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# PostgreSQL with Docker Compose (single compose.yaml):
# - Run `php artisan` on your Mac/PC: use 127.0.0.1 and FORWARD_DB_PORT (default 5432).
#   The app, worker, and scheduler containers override DB_HOST to `postgres` automatically.
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=nrthapp
# DB_USERNAME=dbuser
# DB_PASSWORD=dbpassword

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Redis + queues (use with Horizon / Docker worker)
# QUEUE_CONNECTION=redis
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- S3 / MinIO (self-hosted object storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=nrth
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecretchange

VITE_APP_NAME="${APP_NAME}"
APP_SERVICE=app
APP_USER=root
APP_PORT=8000
VITE_PORT=5173

# Optional Caddy reverse proxy (TLS on 443 → Octane HTTP on app:8000).
# Enable: COMPOSE_PROFILES=proxy then `./scripts/compose.sh up -d`
# COMPOSE_PROFILES=proxy
# CADDY_SITE=books.example.com
# CADDY_TLS=off
# For LAN IP access use self-signed certs:
# CADDY_SITE=192.168.1.204
# CADDY_TLS=internal
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379
FORWARD_MINIO_PORT=9000
FORWARD_MINIO_CONSOLE_PORT=9001
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025

# Vite inside Docker (`sail npm run dev`): compose publishes VITE_PORT (default 5173) and sets
# sensible defaults for server/HMR. Override only if the browser cannot load HMR:
# VITE_DEV_SERVER_HOST=0.0.0.0
# VITE_DEV_SERVER_PORT=5173
# VITE_DEV_SERVER_HMR_HOST=localhost
# VITE_DEV_SERVER_HMR_PORT=5173
# VITE_DEV_SERVER_USE_POLLING=true

# Stripe (Laravel Cashier)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Docker Compose notes:
# - Single compose file: compose.yaml
# - Start stack: docker compose up -d --build
# - Sail wrapper: composer sail -- up -d
# - Containers read this `.env` for credentials, but `compose.yaml` overrides in-network
#   hostnames for app/worker/scheduler: DB_HOST=postgres, REDIS_HOST=redis, MAIL_HOST=mailpit,
#   AWS_ENDPOINT=http://minio:9000
# - Source is bind-mounted into the app container; `vendor` and `node_modules` live in named volumes
#   (populated on first start via entrypoint, or run `sail composer install` / `sail npm ci`).
# - Hot reload: keep `sail npm run dev` running — Vite HMR for Vue/JS/CSS; Vite "refresh" reloads the
#   browser when PHP routes/app/config/views/lang change; Octane runs with `--watch --poll` so PHP edits
#   apply without restarting the container. Horizon (`worker`) may need `docker compose restart worker`
#   after you change queued jobs or listeners.
# - For host `php artisan`, set REDIS_HOST / MAIL_HOST / AWS_ENDPOINT to 127.0.0.1 with the
#   forwarded ports (FORWARD_*), or run commands inside the app container: `sail artisan ...`
